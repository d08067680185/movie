# 复制此文件为 .env 并填写实际值

# 数据库（默认 SQLite，无需修改）
DATABASE_URL=sqlite+aiosqlite:///./movie_search.db

# 管理后台密码（必改！）
ADMIN_PASSWORD=your_strong_password_here

# TMDb API Key（可选，用于影视元数据补全）
TMDB_API_KEY=

# CORS 允许的前端地址（改为实际域名/IP）
# 本地开发:  http://localhost:3000
# 服务器:    http://your-server-ip:3000 或 https://your-domain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 爬虫自动运行间隔（小时）
SPIDER_INTERVAL_HOURS=6
